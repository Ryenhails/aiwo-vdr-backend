# Copy to .env.local and edit for your deployment.
# The `aiwo-rag` provider only activates when AIWO_RAG_BASE_URL is set.

AIWO_RAG_BASE_URL=http://127.0.0.1:8765
AIWO_RAG_MODEL_NAME=AiWo RAG (Ponsse, local Qwen2.5-VL)

# Optional — other providers the TUNI frontend supports. Leave unset to keep
# the dropdown showing only AiWo RAG.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
# AZURE_ANTHROPIC_API_KEY=
# AZURE_ANTHROPIC_BASE_URL=
# AZURE_ANTHROPIC_DEPLOYMENT=claude-opus-4-6
