# Copy to .env.local and edit. Next.js reads .env.local automatically — do
# NOT `export` secrets in your shell. .env.local is gitignored.
#
# A provider only appears in the model dropdown when ALL of its env vars are
# present in this file. Uncomment and fill the ones you actually want.

# ─── AiWo RAG (Aalto backend — default provider for this demo) ────────────
AIWO_RAG_BASE_URL=http://127.0.0.1:8765
AIWO_RAG_MODEL_NAME=AiWo RAG (Ponsse, local Qwen2.5-VL)

# ─── Azure Anthropic (Claude via Azure AI Foundry) ────────────────────────
# Requires BOTH the API key AND the base URL. Set both or neither —
# setting only one keeps the provider hidden.
# AZURE_ANTHROPIC_API_KEY=
# AZURE_ANTHROPIC_BASE_URL=https://<your-resource>.openai.azure.com/anthropic
# AZURE_ANTHROPIC_DEPLOYMENT=claude-opus-4-6

# ─── Anthropic direct ─────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenAI (or an LM-Studio-compatible local server) ─────────────────────
# Registers when EITHER the API key OR the base URL is set.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=

# ─── Google Gemini ────────────────────────────────────────────────────────
# GOOGLE_AI_API_KEY=AIza...

# ─── Ollama (local models) ────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODELS=llama3.3,mistral,phi4
