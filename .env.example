# --- Retrieval + static dirs ---
MODEL_NAME=nanovdr/NanoVDR-S-Multi
INDEX_DIR=data/index
IMAGE_DIR=data/images

# --- Generation backend selector ---
# One of: azure | claude | local
VLM_BACKEND=azure

# azure: Azure OpenAI GPT-4o (legacy default)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
VLM_DEPLOYMENT=gpt-4o

# claude: Anthropic Claude Messages API (vision)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# local: Qwen2.5-VL-Instruct (GPU required)
LOCAL_VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
LOCAL_VLM_DEVICE=cuda
