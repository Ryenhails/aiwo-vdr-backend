# Copy this file to .env and edit in place — the backend loads it automatically
# at startup (via python-dotenv, no shell `export` needed). .env is gitignored.

# --- Retrieval + static dirs (defaults below are fine for the bundled demo) ---
MODEL_NAME=nanovdr/NanoVDR-S-Multi
INDEX_DIR=data/index
IMAGE_DIR=data/images

# --- Generation backend selector ---
# One of: local | claude | azure
VLM_BACKEND=local

# --- local: on-prem Qwen2.5-VL-Instruct (requires a CUDA GPU ≥20 GB) ---
LOCAL_VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
LOCAL_VLM_DEVICE=cuda

# --- claude: Anthropic Messages API (vision) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-6

# --- azure: Azure OpenAI GPT-4o (vision) ---
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-key-here
# VLM_DEPLOYMENT=gpt-4o
